{
  "name": "server",
  "version": "1.0.0",
  "description": "Backend API server generated by create-node-server",
  "private": true,
  "type": "module",

  "engines": {
    "node": ">=20"
  },

  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",

    "lint": "eslint .",
    "lint:fix": "eslint . --fix",

    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },

  "dependencies": {
    "express": "^5.1.0",
    "dotenv": "^17.2.0"
  },

  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",

    "typescript": "^5.8.3",
    "tsx": "^4.19.4",

    "eslint": "^9.31.0",
    "@eslint/js": "^9.31.0",
    "typescript-eslint": "^8.36.0",
    "eslint-config-prettier": "^10.1.5",

    "prettier": "^3.6.2"
  }
}